APP_ENV=development   # development | production

# Local dev: start postgres with `docker compose up postgres -d` from the repo root,
# then run `alembic upgrade head` to apply migrations.
DATABASE_URL=postgresql+asyncpg://kfit:kfit@localhost:5432/kfit

# Production (internal, container-to-container):
# DATABASE_URL=postgresql+asyncpg://kfit:kfit@postgres:5432/kfit

# Auth
JWT_SECRET=change-me-generate-with-secrets-token-hex-32

# Onboarding token — stateless HMAC, no DB needed.
# Generate secret with: python -c "import secrets; print(secrets.token_hex(32))"
ONBOARDING_SECRET=change-me-onboarding-secret
LANDING_BASE_URL=https://k-fit.co.il

# Static API key for automation (n8n, etc.) — non-expiring
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTOMATION_API_KEY=

# OpenAI (meal-planner agent). Leave blank until wiring the LLM step.
OPENAI_API_KEY=
# Fast model builds the first proposal; stronger reasoning model handles repair.
OPENAI_BUILDER_MODEL=gpt-4o
OPENAI_REPAIR_MODEL=o4-mini
OPENAI_ANALYZER_MODEL=gpt-4o

# CORS — JSON array of allowed browser origins
CORS_ORIGINS=["http://localhost:3000","https://admin.k-fit.co.il"]

# Local dev: start minio with `docker compose up minio -d` from the repo root.
MINIO_INTERNAL_URL=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000

# Production:
# MINIO_INTERNAL_URL=http://minio:9000
# MINIO_PUBLIC_URL=https://cdn.k-fit.co.il
MINIO_ACCESS_KEY=kfit
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=kfit
